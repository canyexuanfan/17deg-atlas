{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kb://schemas/trusted-search-result-v1",
  "title": "KB3 trusted search result",
  "type": "object",
  "required": ["object_id", "object_kind", "tier", "classification", "scope", "title", "summary", "snippet", "canonical", "outdated", "source_ids", "source_chain", "raw_source_ids", "score", "explanation"],
  "properties": {
    "object_id": {"type": "string"},
    "object_kind": {"enum": ["raw", "wiki", "release"]},
    "tier": {"enum": ["public", "archive", "basic", "advanced", "core"]},
    "classification": {"enum": ["public", "basic", "advanced", "core"]},
    "scope": {"enum": ["private", "collaboration", "public"]},
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "snippet": {"type": "string"},
    "wiki_kind": {"type": ["string", "null"]},
    "card_kind": {"type": ["string", "null"]},
    "topic_ids": {"type": "array", "items": {"type": "string"}},
    "review_state": {"type": "string"},
    "lifecycle": {"type": "string"},
    "canonical": {"type": "boolean"},
    "superseded_by": {"type": "array", "items": {"type": "string"}},
    "conflicts_with": {"type": "array", "items": {"type": "string"}},
    "outdated": {"type": "boolean"},
    "source_ids": {"type": "array", "items": {"type": "string"}},
    "source_chain": {"type": "array", "items": {"type": "string"}},
    "raw_source_ids": {"type": "array", "items": {"type": "string"}},
    "path": {"type": "string"},
    "updated_at": {"type": "string"},
    "score": {"type": "number"},
    "explanation": {"type": "object"}
  },
  "additionalProperties": false
}
